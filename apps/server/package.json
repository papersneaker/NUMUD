{
  "name": "@ephemera/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && esbuild dist/index.js --bundle --platform=node --outfile=dist/server.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/postgres/seed.ts"
  },
  "dependencies": {
    "@ephemera/shared": "workspace:*",
    "socket.io": "^4.8.1",
    "drizzle-orm": "^0.39.1",
    "pg": "^8.13.1",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.10.5",
    "drizzle-kit": "^0.30.1",
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}